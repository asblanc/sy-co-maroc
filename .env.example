# SY&CO — environment variables
# Copy to .env.local for local dev, and set these in Vercel → Project → Settings → Environment Variables.

# Public site URL (canonical URLs, sitemap, Open Graph).
# OPTIONAL — auto-detected from Vercel (VERCEL_URL) when omitted.
# If you set it, use a full valid URL, e.g. https://sy-co-maroc.vercel.app
# NEXT_PUBLIC_SITE_URL=https://sy-co-maroc.vercel.app

# Supabase — contact form lead capture (optional; form degrades gracefully if unset)
NEXT_PUBLIC_SUPABASE_URL=https://wmsfmmymiwddtmuqhxue.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-or-publishable-key
